[Unit]
Description=YiYu Feishu OAuth Relay
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/srv/yiyu-oauth-relay
Environment=PYTHONUNBUFFERED=1
Environment=YIYU_FEISHU_OAUTH_RELAY_DB=/var/lib/yiyu-oauth-relay/relay.sqlite3
ExecStart=/usr/bin/python3 /srv/yiyu-oauth-relay/services/feishu_oauth_relay/standalone.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
