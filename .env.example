# 益语智库工作台本地开发配置模板
#
# 用法：
#   cp .env.example .env
#   # 按需填写自己的配置；真实 .env 不要提交

# 桌面端连接的云端协作服务。留空时使用本机/内置云端能力。
YIYU_REMOTE_CLOUD_API_URL=

# 云端后端服务密钥。生产环境必须使用足够长的随机值。
YIYU_CLOUD_SECRET_KEY=replace-with-a-strong-random-secret
YIYU_CLOUD_PUBLIC_BASE_URL=http://localhost:47830

# 初始管理员配置，仅用于自建云端初始化。
YIYU_CLOUD_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
YIYU_CLOUD_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# 大模型配置。按自己使用的供应商填写。
YIYU_LLM_PROVIDER=
YIYU_LLM_BASE_URL=
YIYU_LLM_API_KEY=
YIYU_LLM_MODEL=

# 可选：OpenAI / DashScope / 火山方舟等供应商环境变量。
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ARK_API_KEY=

# 飞书集成。只填写自己创建的飞书应用。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_WEBHOOK=

# 对象存储。可使用任意 S3/TOS 兼容服务。
OBJECT_STORAGE_PROVIDER=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=

# 语音转写。可使用本地模型或云端模型。
SPEECH_PROVIDER=
SPEECH_MODEL=
SPEECH_APP_ID=
SPEECH_ACCESS_TOKEN=

# 桌面端更新源。正式分发时指向你自己的更新清单目录。
YIYU_UPDATE_FEED_URL=

