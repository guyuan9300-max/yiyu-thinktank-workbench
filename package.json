{
  "name": "yiyu-thinktank-workbench",
  "version": "0.24.0",
  "description": "益语智库自用平台 V2.0 桌面版",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "build/main/main.js",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on tcp:4173 build/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:4173 node scripts/run-local-electron.mjs .",
    "dev:electron:local-cloud": "wait-on tcp:4173 build/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:4173 node scripts/run-local-electron.mjs .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer:lab": "vite --host 127.0.0.1 --port 4174 --strictPort",
    "dev:electron:lab": "wait-on tcp:4174 build/main/main.js && cross-env YIYU_LAB_MODE=1 VITE_DEV_SERVER_URL=http://127.0.0.1:4174 node scripts/run-local-electron.mjs .",
    "dev:lab": "concurrently -k \"npm:dev:renderer:lab\" \"npm:dev:main\" \"npm:dev:electron:lab\"",
    "typecheck:renderer": "tsc --noEmit --pretty false --incremental false -p tsconfig.json",
    "build:renderer": "npm run typecheck:renderer && vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build:backend-check": "cd backend && python3 -m compileall app",
    "build:version-manifest": "node scripts/write-version-manifest.mjs",
    "build:packaged-runtime": "node scripts/build-packaged-runtime.mjs",
    "build:mac-icon": "python3 scripts/generate-mac-icon.py",
    "build": "npm run build:main && npm run build:renderer && npm run build:backend-check && npm run build:version-manifest",
    "test:calendar": "npm run build:main && node --test build/shared/calendar.test.js",
    "test:collab-merge": "npm run build:main && node scripts/test-collab-merge.mjs",
    "backend:test": "cd backend && uv run pytest",
    "cloud:test": "cd cloud_backend && uv run pytest",
    "db:init:lab": "python3 scripts/init_v21_lab_schema.py",
    "db:check:lab": "python3 scripts/init_v21_lab_schema.py --check-only",
    "start": "node scripts/open-installed-app.mjs",
    "start:raw": "node scripts/run-local-electron.mjs .",
    "install:mac-local": "npm run dist:mac-local && node scripts/install-mac-app.mjs && node scripts/open-installed-app.mjs",
    "dist:mac": "node scripts/ensure-mac-release-prereqs.mjs && npm run build && npm run build:packaged-runtime && electron-builder --mac dmg zip -c.electronDist=node_modules/electron/dist && node scripts/verify-packaged-app.mjs \"dist/mac-arm64/益语智库AI.app\"",
    "dist:windows": "npm run build && npm run build:packaged-runtime && electron-builder --win nsis --x64 -c.publish.url=https://yiyu-thinktank-releases.tos-cn-beijing.volces.com/desktop/windows/",
    "dist:mac-local": "npm run build && npm run build:packaged-runtime && electron-builder --dir -c.electronDist=node_modules/electron/dist -c.mac.identity=null -c.mac.hardenedRuntime=false -c.mac.gatekeeperAssess=false -c.mac.forceCodeSigning=false -c.mac.notarize=false && node scripts/stabilize-mac-app.mjs \"dist/mac-arm64/益语智库AI.app\" && node scripts/verify-packaged-app.mjs \"dist/mac-arm64/益语智库AI.app\"",
    "release:mac:doctor": "node scripts/inspect-mac-release-readiness.mjs",
    "release:mac:doctor:strict": "node scripts/inspect-mac-release-readiness.mjs --strict",
    "release:mac": "npm run dist:mac",
    "release:windows": "npm run dist:windows",
    "release:windows:refresh-metadata": "node scripts/refresh-windows-update-metadata.mjs",
    "release:windows:publish": "node scripts/publish-windows-to-tos.mjs",
    "release:windows:publish:dry": "node scripts/publish-windows-to-tos.mjs --dry-run",
    "release:mac:verify-dmg": "node scripts/verify-mac-dmg.mjs",
    "release:mac:publish": "node scripts/publish-to-tos.mjs",
    "release:mac:publish:dry": "node scripts/publish-to-tos.mjs --dry-run",
    "release:mac:tos": "node scripts/release-mac-to-tos.mjs",
    "check:source-cleanliness": "node scripts/check-source-cleanliness.mjs"
  },
  "build": {
    "appId": "com.yiyu.selfworkbench2",
    "productName": "益语智库AI",
    "asar": false,
    "directories": {
      "buildResources": "build-resources"
    },
    "afterPack": "scripts/after-pack-mac.cjs",
    "extraResources": [
      {
        "from": "dist/packaged-runtime",
        "to": "runtime"
      }
    ],
    "files": [
      "build/**/*",
      "!**/*.map",
      "dist/renderer/**/*",
      "dist/version-manifest.json",
      ".yiyu-sync/**/*",
      "backend/**/*",
      "!backend/.venv{,/**}",
      "!backend/tests{,/**}",
      "!backend/output{,/**}",
      "!backend/.pytest_cache{,/**}",
      "!backend/.mypy_cache{,/**}",
      "!backend/.ruff_cache{,/**}",
      "!backend/**/__pycache__{,/**}",
      "!backend/*.db",
      "!backend/*.db-*",
      "!backend/**/*.db",
      "!backend/**/*.db-*",
      "!backend/*.sqlite",
      "!backend/**/*.sqlite",
      "!backend/*.sqlite3",
      "!backend/**/*.sqlite3",
      "!backend/.env",
      "!backend/.env.*",
      "!backend/**/.env",
      "!backend/**/.env.*",
      "!backend/**/*.pyc",
      "!backend/**/*.pyo",
      "!backend/**/*.cstemp",
      "cloud_backend/**/*",
      "!cloud_backend/.venv{,/**}",
      "!cloud_backend/tests{,/**}",
      "!cloud_backend/output{,/**}",
      "!cloud_backend/.pytest_cache{,/**}",
      "!cloud_backend/.mypy_cache{,/**}",
      "!cloud_backend/.ruff_cache{,/**}",
      "!cloud_backend/**/__pycache__{,/**}",
      "!cloud_backend/*.db",
      "!cloud_backend/*.db-*",
      "!cloud_backend/**/*.db",
      "!cloud_backend/**/*.db-*",
      "!cloud_backend/*.sqlite",
      "!cloud_backend/**/*.sqlite",
      "!cloud_backend/*.sqlite3",
      "!cloud_backend/**/*.sqlite3",
      "!cloud_backend/.env",
      "!cloud_backend/.env.*",
      "!cloud_backend/**/.env",
      "!cloud_backend/**/.env.*",
      "!cloud_backend/**/*.pyc",
      "!cloud_backend/**/*.pyo",
      "!cloud_backend/**/*.cstemp",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.inherit.plist",
      "forceCodeSigning": true,
      "notarize": true,
      "signIgnore": [
        "/Contents/Resources/runtime/backend-venv-prebuilt/lib/python3\\.11/site-packages/pytz/zoneinfo/",
        "/Contents/Resources/runtime/backend-venv-prebuilt/lib/python3\\.11/site-packages/matplotlib/mpl-data/",
        "\\.(?:tar\\.gz|whl|docx|pptx|xlsx|jpeg|jpg|png|gif|icns|ico|ttf|otf|afm|pfb|pdf|csv)$"
      ],
      "artifactName": "yiyu-workbench-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "yiyu-workbench-${version}-${arch}-setup.${ext}",
      "verifyUpdateCodeSignature": true,
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "publisherName": "Yiyu Thinktank",
        "rfc3161TimeStampServer": "http://timestamp.digicert.com",
        "timeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "益语智库自用平台 V2.0"
    },
    "publish": {
      "provider": "generic",
      "url": "https://yiyu-thinktank-releases.tos-cn-beijing.volces.com/desktop/mac/",
      "channel": "latest"
    }
  },
  "dependencies": {
    "@mdxeditor/editor": "^4.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.511.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-activity-calendar": "^3.2.0",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.6.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  }
}
