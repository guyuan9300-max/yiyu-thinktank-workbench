# 益语智库自用平台 V2.0 — Mac 正式发布环境变量模板
#
# 用法：
#   cp .env.release.example .env.release
#   # 然后填入真实凭据
#   set -a; source .env.release; set +a
#   npm run release:mac:doctor:strict
#
# 安全规则：
#   - .env.release 已被 .gitignore 排除，绝对不要提交
#   - .p8 / .p12 / .cer / .certSigningRequest 同样禁止入库
#   - 私钥只留在这台发布机器的钥匙串和受控目录里
#
# 推荐使用 App Store Connect API Key 方式（更稳，不依赖个人 Apple ID）：
APPLE_API_KEY="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
APPLE_API_KEY_ID="XXXXXXXXXX"
APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# 可选：如果暂时只能用 Apple ID + app-specific password，取消下面三行注释并删除上面三行
# APPLE_ID="your-apple-id@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="XXXXXXXXXX"

# 可选：显式指定签名身份（一般不需要，electron-builder 会自动从钥匙串挑 Developer ID Application）
# CSC_NAME="Developer ID Application: 你的名字 (TEAMID)"
